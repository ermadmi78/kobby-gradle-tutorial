directive @resolve on FIELD_DEFINITION

type Query {
    film(id: ID!): Film
    films: [Film!]!
}

type Mutation {
    createFilm(title: String!): Film!
}

type Subscription {
    filmCreated: Film!
}

type Film {
    id: ID!
    title: String!
    actors: [Actor!]! @resolve
}

type Actor {
    id: ID!
    firstName: String!
    lastName: String
}